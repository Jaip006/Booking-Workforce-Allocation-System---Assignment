  "scripts": {
    "dev": "node node_modules/ts-node-dev/lib/bin.js --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "node node_modules/ts-node/dist/bin.js src/seed.ts",
